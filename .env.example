# OpenTaiMed environment variables — copy to .env and fill in actual values
# .env is gitignored; this template is committed

# ============================================================================
# LLM Provider
# ============================================================================

# Dev mode: LiteLLM proxy (internal TSGH-DMC infrastructure)
# Get the actual URL + key from TSGH-DMC internal documentation
LITELLM_PROXY_URL=https://<internal-proxy-host>/litellm/
LITELLM_API_KEY=<get-from-tsgh-dmc-internal>

# Prod mode: Gemini Direct API (when ready to deploy)
# GEMINI_API_KEY=<your-personal-gemini-api-key>
# GEMINI_DAILY_BUDGET_USD=<e.g. 5.00>

# ============================================================================
# Supabase Auth (self-hosted, see spec §14.4)
# ============================================================================

SUPABASE_URL=https://supabase.opentaimed.local
SUPABASE_ANON_KEY=<from-supabase-dashboard>
SUPABASE_SERVICE_ROLE_KEY=<from-supabase-dashboard-keep-secret>

# ============================================================================
# Cloudflare Turnstile (abuse defense, see spec §14.3)
# ============================================================================

TURNSTILE_SITE_KEY=<public-site-key>
TURNSTILE_SECRET_KEY=<keep-secret>

# ============================================================================
# Application
# ============================================================================

NEXT_PUBLIC_APP_URL=https://opentaimed.local
APP_ENV=development  # development | staging | production

# ============================================================================
# FDA API (public, no key needed, but configurable for testing)
# ============================================================================

FDA_API_BASE_URL=https://mcp.fda.gov.tw
FDA_API_RATE_LIMIT_INTERVAL_SECONDS=0.5

# ============================================================================
# MCP Server (internal, see spec §14.8)
# ============================================================================

MCP_SERVER_URL=mcp://taiwan-fda-mcp:8765
MCP_HMAC_SECRET=<generate-with: openssl rand -hex 32>
