{
  "description": "Response shape for `check_insert_updates`.",
  "properties": {
    "batch_errors": {
      "description": "Per-window failures (surfaced rather than swallowed).",
      "items": {
        "description": "One per-window failure in `check_insert_updates.batch_errors`.\n\nSurfaced (not swallowed) so the caller knows part of the date range\nfailed and can decide whether to retry that window.",
        "properties": {
          "code": {
            "description": "RCode name.",
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "window": {
            "description": "[start_iso, end_iso] of the 10-day batch that failed.",
            "items": {
              "type": "string"
            },
            "type": "array"
          }
        },
        "required": [
          "window",
          "code",
          "message"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "by_date": {
      "additionalProperties": {
        "type": "integer"
      },
      "description": "Histogram of {YYYY-MM-DD: count}, sorted newest-first.",
      "type": "object"
    },
    "error": {
      "anyOf": [
        {
          "description": "Structured error block. `code` is the RCode name (string form, stable identifier).",
          "properties": {
            "code": {
              "description": "Stable error code identifier (e.g. 'INSERT_NOT_FOUND').",
              "type": "string"
            },
            "message": {
              "description": "Human-readable error message in Traditional Chinese or English.",
              "type": "string"
            }
          },
          "required": [
            "code",
            "message"
          ],
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Top-level error if the whole call failed."
    },
    "since_date": {
      "description": "Lower bound of the date range (echo, ISO format).",
      "type": "string"
    },
    "today": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Upper bound (defaults to today UTC)."
    },
    "total": {
      "default": 0,
      "description": "Number of unique inserts updated in the window.",
      "type": "integer"
    },
    "updates": {
      "description": "List of updated inserts, sorted by last_update_date descending.",
      "items": {
        "description": "One updated insert in `check_insert_updates.updates`.",
        "properties": {
          "last_update_date": {
            "type": "string"
          },
          "license_no": {
            "type": "string"
          },
          "name_zh": {
            "type": "string"
          }
        },
        "required": [
          "license_no",
          "name_zh",
          "last_update_date"
        ],
        "type": "object"
      },
      "type": "array"
    }
  },
  "required": [
    "since_date"
  ],
  "type": "object"
}
