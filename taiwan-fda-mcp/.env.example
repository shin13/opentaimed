# taiwan-fda-mcp configuration. Copy to .env and override only what you need.
# .env is gitignored; every var below is optional and has a working default.

# --- FDA APIs (public, no key needed; override for testing only) -------------
FDA_INSERT_BASE_URL=https://mcp.fda.gov.tw
FDA_OPENDATA_BASE_URL=https://data.fda.gov.tw

# Good-citizen throttle: seconds to sleep after each upstream request (insert
# fetch + background Dataset 37 refresh). Keep > 0 against the live gov APIs.
FDA_RATE_LIMIT_INTERVAL_SECONDS=0.5

# --- Dataset 37 search index -------------------------------------------------
# By default the cache lives in the per-user OS cache dir (platformdirs), e.g.
# ~/Library/Caches/taiwan-fda-mcp/dataset37 (macOS) — uvx-safe, survives across
# ephemeral installs. Uncomment ONLY to pin it elsewhere; a cwd-relative path
# would break ephemeral `uvx` runs.
# DATASET37_CACHE_DIR=/abs/path/to/dataset37

# Stale-while-revalidate TTL (hours). Past this age, a query serves the cached
# index immediately and refreshes it in the background (ADR-0009).
DATASET37_TTL_HOURS=24

# --- Package-insert cache (ADR-0011) -----------------------------------------
# OFF by default. When on, get_package_insert caches the raw GetDrugDoc XML per
# license in process memory and re-parses on hit, cutting repeat egress to
# mcp.fda.gov.tw — most useful for the shared HTTP service (Model B), where every
# clinician's lookup leaves through one IP. Individual `uvx` users can leave it
# off (ADR-0009 live-fetch). Responses carry from_cache + cache_age_hours;
# last_update_date (clinical currency) is unaffected by caching. In-memory only,
# single-instance, wiped on restart. Empty / unparseable responses are never
# cached (no false "not found").
# INSERT_CACHE_ENABLED=false
# INSERT_CACHE_TTL_HOURS=6         # short: inserts are clinically-live content
# INSERT_CACHE_MAX_ENTRIES=1000    # evicted oldest-first when exceeded
# INSERT_CACHE_MAX_MB=128          # RAM ceiling; a single larger insert is served but not cached

# --- Logging -----------------------------------------------------------------
LOG_LEVEL=INFO

# --- Shared HTTP service transport (ADR-0010 Stage 1) ------------------------
# Default stdio = individual `uvx` use. Set http to run the institutional
# shared service. TLS terminates at a reverse-proxy edge (see docker-compose.yml);
# this service speaks plain HTTP only and holds no certificate.
# MCP_TRANSPORT=stdio        # stdio | http
# MCP_HTTP_HOST=127.0.0.1    # the Docker image overrides this to 0.0.0.0
# MCP_HTTP_PORT=8765
# MCP_HTTP_PATH=/mcp/        # trailing slash required (FastMCP default)
