# taiwan-fda-mcp configuration. Copy to .env and override only what you need.
# .env is gitignored; every var below is optional and has a working default.

# --- FDA APIs (public, no key needed; override for testing only) -------------
FDA_INSERT_BASE_URL=https://mcp.fda.gov.tw
FDA_OPENDATA_BASE_URL=https://data.fda.gov.tw

# Good-citizen throttle: seconds to sleep after each upstream request (insert
# fetch + background Dataset 37 refresh). Keep > 0 against the live gov APIs.
FDA_RATE_LIMIT_INTERVAL_SECONDS=0.5

# --- Dataset 37 search index -------------------------------------------------
# By default the cache lives in the per-user OS cache dir (platformdirs), e.g.
# ~/Library/Caches/taiwan-fda-mcp/dataset37 (macOS) — uvx-safe, survives across
# ephemeral installs. Uncomment ONLY to pin it elsewhere; a cwd-relative path
# would break ephemeral `uvx` runs.
# DATASET37_CACHE_DIR=/abs/path/to/dataset37

# Stale-while-revalidate TTL (hours). Past this age, a query serves the cached
# index immediately and refreshes it in the background (ADR-0009).
DATASET37_TTL_HOURS=24

# --- Logging -----------------------------------------------------------------
LOG_LEVEL=INFO

# --- Reserved: shared HTTP-service transport (Phase 3 / ADR-0010, not yet wired)
# The server runs over stdio by default. These are placeholders for the planned
# institutional HTTP deployment and are not read by the current code.
# MCP_TRANSPORT=stdio       # stdio | http
# MCP_HTTP_HOST=127.0.0.1
# MCP_HTTP_PORT=8765
